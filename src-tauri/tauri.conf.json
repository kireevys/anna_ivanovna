{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anna Ivanovna",
  "version": "1.0.1",
  "identifier": "com.kireev.anna_ivanovna",
  "build": {
    "beforeDevCommand": "trunk serve --port 31416 --config frontend/Trunk.toml --features tauri",
    "devUrl": "http://localhost:31416",
    "beforeBuildCommand": "trunk build --config frontend/Trunk.toml --features tauri",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anna Ivanovna",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
