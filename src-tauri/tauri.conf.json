{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anna Ivanovna",
  "identifier": "com.kireev.buhanna",
  "build": {
    "beforeDevCommand": "trunk serve --port 31416 --features tauri",
    "devUrl": "http://localhost:31416",
    "beforeBuildCommand": "trunk build --features tauri",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BuhAnna",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
